public class wo{
    public static void main(String[] args) {
        String input = "have a nice day";
        String[] word = input.split(" ");
        String rev = "";
        for (int i = word.length - 1; i >= 0; i--) {
            rev = rev + word[i];
            if (i > 0) {
                rev = rev + " ";
            }
        }
        System.out.println(rev);
    }
}
