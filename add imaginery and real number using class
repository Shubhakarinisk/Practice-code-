class Complex {
    double real;
    double imag;
    Complex(double r, double i) {
        this.real = r;
        this.imag = i;
    }
    public Complex add(Complex num2) {
        double totalReal = this.real + num2.real;
        double totalImag = this.imag + num2.imag;
        return new Complex(totalReal, totalImag);
    }
    public void display() {
        System.out.println(this.real + " + " + this.imag + "i");
    }
}
public class Main {
    public static void main(String[] args) {
        Complex c1 = new Complex(4.5, 2.0);
        Complex c2 = new Complex(3.0, 5.5);
        System.out.print("First Complex Number: ");
        c1.display();
        System.out.print("Second Complex Number: ");
        c2.display();
        Complex result = c1.add(c2);
        System.out.print("Sum: ");
        result.display();
    }
}
